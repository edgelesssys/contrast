From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Charlotte Hartmann Paludo <git@charlotteharludo.com>
Date: Wed, 17 Jun 2026 10:51:43 +0200
Subject: [PATCH] runtime-rs: change `safe-path` dependency from crates.io to
 workspace

---
 Cargo.lock                                  | 21 ++++++---------------
 src/runtime-rs/crates/hypervisor/Cargo.toml |  2 +-
 2 files changed, 7 insertions(+), 16 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index d3d9b4c6aa8f0385d04d9593e189f8d5a8bcf49d..9a920e9fcfa032e2b6adf3e7eba6d49eac3f7353 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -2874,7 +2874,7 @@ dependencies = [
  "rand 0.10.1",
  "regex",
  "rust-ini",
- "safe-path 0.1.0 (registry+https://github.com/rust-lang/crates.io-index)",
+ "safe-path",
  "seccompiler",
  "serde",
  "serde_json",
@@ -3432,7 +3432,7 @@ dependencies = [
  "runtime-spec",
  "rustjail",
  "s390_pv_core",
- "safe-path 0.1.0",
+ "safe-path",
  "scan_fmt",
  "scopeguard",
  "serde",
@@ -3480,7 +3480,7 @@ dependencies = [
  "protobuf",
  "protocols",
  "rand 0.10.1",
- "safe-path 0.1.0",
+ "safe-path",
  "serde",
  "serde_json",
  "slog",
@@ -3638,7 +3638,7 @@ dependencies = [
  "oci-spec 0.8.4",
  "regex",
  "rstest 0.18.2",
- "safe-path 0.1.0",
+ "safe-path",
  "serde",
  "serde-enum-str",
  "serde_json",
@@ -5051,7 +5051,7 @@ dependencies = [
  "async-trait",
  "kata-sys-util",
  "kata-types",
- "safe-path 0.1.0",
+ "safe-path",
  "serde",
  "serde_json",
 ]
@@ -6543,7 +6543,7 @@ dependencies = [
  "regex",
  "rlimit 0.5.4",
  "runtime-spec",
- "safe-path 0.1.0",
+ "safe-path",
  "scan_fmt",
  "scopeguard",
  "serde",
@@ -6670,15 +6670,6 @@ dependencies = [
  "tempfile",
 ]
 
-[[package]]
-name = "safe-path"
-version = "0.1.0"
-source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "980abdd3220aa19b67ca3ea07b173ca36383f18ae48cde696d90c8af39447ffb"
-dependencies = [
- "libc",
-]
-
 [[package]]
 name = "same-file"
 version = "1.0.6"
diff --git a/src/runtime-rs/crates/hypervisor/Cargo.toml b/src/runtime-rs/crates/hypervisor/Cargo.toml
index 6e4bde486eb293ca2c555fa4133727ed23b4582c..86b6eeaa841282d919f82d36ca11cd8e05d4e23c 100644
--- a/src/runtime-rs/crates/hypervisor/Cargo.toml
+++ b/src/runtime-rs/crates/hypervisor/Cargo.toml
@@ -29,7 +29,6 @@ lazy_static = { workspace = true }
 tracing = { workspace = true }
 ttrpc = { workspace = true, features = ["async"] }
 futures = "0.3.25"
-safe-path = "0.1.0"
 crossbeam-channel = "0.5.6"
 qapi = { version = "0.15", features = ["qmp", "async-tokio-all"] }
 qapi-spec = "0.3.2"
@@ -44,6 +43,7 @@ logging = { workspace = true }
 protocols = { workspace = true, features = ["async"] }
 persist = { workspace = true }
 ch-config = { workspace = true, optional = true }
+safe-path = { workspace = true }
 tests_utils = { workspace = true }
 
 # Dependencies that only exist to support hypervisors which upstream only
