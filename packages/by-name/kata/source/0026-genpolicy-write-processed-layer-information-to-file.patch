+
     #[clap(short, long, help = "Print version information and exit")]
     version: bool,
 
@@ -138,6 +145,7 @@ pub struct Config {
     pub base64_out: bool,
     pub containerd_socket_path: Option<String>,
     pub layers_cache: layers_cache::ImageLayersCache,
