     let mut layers = Vec::new();
-
+    let mut index_layers = Vec::new();
     for layer in &manifest.layers {
         if layer
             .media_type
@@ -541,15 +563,20 @@ async fn get_image_layers(
             || layer.media_type.eq(manifest::IMAGE_LAYER_GZIP_MEDIA_TYPE)
         {
