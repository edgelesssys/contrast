+}
+
+/// Layer information for one specific image.
+#[derive(Clone, Debug, Serialize, Deserialize)]
+pub struct ImageLayerIndex {
+    pub image_ref: String,
+    pub layers: Vec<ImageLayerIndexEntry>,
+}
+
+/// The DiffID and compressed size of a layer.
+#[derive(Clone, Debug, Serialize, Deserialize)]
+pub struct ImageLayerIndexEntry {
+    pub diff_id: String,
+    pub compressed_size: u64,
+}
+
+#[derive(Clone, Debug, Serialize, Deserialize)]
+#[serde(untagged)]
+pub enum ImageLayersCacheEntry {
+    Layer(ImageLayer),
+    ImageIndex(ImageLayerIndex),
 }
 
 /// See https://docs.docker.com/reference/dockerfile/#volume.
@@ -533,7 +555,7 @@ async fn get_image_layers(
 ) -> Result<Vec<ImageLayer>> {
