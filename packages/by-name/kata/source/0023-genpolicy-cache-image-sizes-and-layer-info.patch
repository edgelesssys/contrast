         }
     }
 
-    fn try_new(layers_cache_file_path: &Option<String>) -> std::io::Result<Vec<ImageLayer>> {
+    fn try_new(
+        layers_cache_file_path: &Option<String>,
+    ) -> std::io::Result<Vec<ImageLayersCacheEntry>> {
         match &layers_cache_file_path {
             Some(filename) => {
                 let file = OpenOptions::new()
@@ -44,7 +46,8 @@ impl ImageLayersCache {
                 // In this case, the cache will simply not be used for this instance.
                 FileExt::try_lock_shared(&file)?;
 
-                let initial_state: Vec<ImageLayer> = match serde_json::from_reader(&file) {
+                let initial_state: Vec<ImageLayersCacheEntry> = match serde_json::from_reader(&file)
+                {
                     Ok(data) => data,
                     Err(e) if e.is_eof() => Vec::new(), // empty file
                     Err(e) => {
@@ -61,15 +64,27 @@ impl ImageLayersCache {
 
     pub fn get_layer(&self, diff_id: &str) -> Option<ImageLayer> {
         let layers = self.inner.lock().unwrap();
-        layers
-            .iter()
-            .find(|layer| layer.diff_id == diff_id)
-            .cloned()
+        layers.iter().find_map(|entry| match entry {
+            ImageLayersCacheEntry::Layer(layer) if layer.diff_id == diff_id => Some(layer.clone()),
+            _ => None,
+        })
     }
 
     pub fn insert_layer(&self, layer: &ImageLayer) {
         let mut layers = self.inner.lock().unwrap();
-        layers.push(layer.clone());
+        layers.push(ImageLayersCacheEntry::Layer(layer.clone()));
+    }
+
+    pub fn insert_image_index(&self, index: &ImageLayerIndex) {
+        let mut layers = self.inner.lock().unwrap();
+        if let Some(entry) = layers.iter_mut().find(|entry| match entry {
+            ImageLayersCacheEntry::ImageIndex(existing) => existing.image_ref == index.image_ref,
+            _ => false,
+        }) {
+            *entry = ImageLayersCacheEntry::ImageIndex(index.clone());
+            return;
+        }
+        layers.push(ImageLayersCacheEntry::ImageIndex(index.clone()));
     }
 
     pub fn persist(&self) {
diff --git a/src/tools/genpolicy/src/registry.rs b/src/tools/genpolicy/src/registry.rs
index abcd7ef7adcf0e09c43510a4f8c2e347510da0f5..e20c243d4075f98166d8735048eaa6d246b47e51 100644
