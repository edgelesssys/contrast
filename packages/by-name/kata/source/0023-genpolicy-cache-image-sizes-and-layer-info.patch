                 )
                 .await?;
-                imageLayer.diff_id = config_layer.rootfs.diff_ids[layer_index].clone();
+                index_layers.push(ImageLayerIndexEntry {
+                    diff_id: diff_id.to_string(),
+                    compressed_size,
+                });
                 layers.push(imageLayer);
             } else {
                 return Err(anyhow!("Too many Docker gzip layers"));
@@ -559,6 +586,11 @@ async fn get_image_layers(
         }
     }
 
+    layers_cache.insert_image_index(&ImageLayerIndex {
+        image_ref: reference.to_string(),
+        layers: index_layers,
