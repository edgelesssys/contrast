 	span, ctx := katatrace.Trace(ctx, q.Logger(), "StartVM", qemuTracingTags, map[string]string{"sandbox_id": q.id})
@@ -1453,20 +1486,23 @@ func (q *qemu) loopQMPEvent(event chan govmmQemu.QMPEvent) {
