+  @param[in] DataSize    Size of the data in bytes.
+
+  @retval EFI_SUCCESS    Verification succeeded (or skipped).
+**/
+STATIC
+EFI_STATUS
+VerifyTableLoaderData (
+  IN CONST VOID  *Data,
+  IN UINTN       DataSize
+  )
+{
+  return EFI_SUCCESS;
+}
