diff --git a/nix/runtime-dependencies.nix b/nix/runtime-dependencies.nix
index 8e65af8..ba4be70 100644
--- a/nix/runtime-dependencies.nix
+++ b/nix/runtime-dependencies.nix
@@ -1,11 +1,21 @@
-# This is a wrapper around nixpkgs' closureInfo. It returns a newline
-# separated list of the store paths of drv's runtime dependencies.
+# This returns a JSON file describing drv's runtime dependency graph: an array
+# of { path, references } objects, one per store path in the closure of drv (and
+# extraPaths). `references` are the direct runtime references of `path`. This is
+# the data needed to emit a CycloneDX `dependencies` graph; `exportReferencesGraph`
+# gives us exactly the edges that `closureInfo` knows about.
 {
   runCommand,
-  closureInfo,
+  jq,
 }:
 
 drv: extraPaths:
-runCommand "${drv.name}-runtime-dependencies.txt" { } ''
-  cat ${closureInfo { rootPaths = [ drv ] ++ extraPaths; }}/store-paths > $out
-''
+runCommand "${drv.name}-runtime-dependencies.json"
+  {
+    __structuredAttrs = true;
+    exportReferencesGraph.closure = [ drv ] ++ extraPaths;
+    nativeBuildInputs = [ jq ];
+  }
+  ''
+    jq '[.closure[] | { path: .path, references: .references }]' \
+      "$NIX_ATTRS_JSON_FILE" > "$out"
+  ''
